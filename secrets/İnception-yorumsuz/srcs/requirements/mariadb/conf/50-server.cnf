# MariaDB / MySQL server configuration file
# Bölümler [mysqld] gibi başlıklarla ayrılır; bu bölümde mysqld daemon'ı için ayarlar var
[mysqld]
# user : mysqld süreçlerini hangi kullanıcı olarak çalıştıracağını belirtir
user                    = mysql
# pid-file : mysqld'nin PID dosyasının yolu (process id depolama)
pid-file                = /run/mysqld/mysqld.pid
# socket : unix domain socket dosyasının yolu (local bağlantılar için)
socket                  = /run/mysqld/mysqld.sock
# port : TCP port, varsayılan MySQL portu 3306
port                    = 3306
# basedir : MariaDB'nin kurulu olduğu temel dizin
basedir                 = /usr
# datadir : veritabanı dosyalarının tutulduğu dizin
datadir                 = /var/lib/mysql
# tmpdir : geçici dosyaların tutulduğu dizin
tmpdir                  = /tmp
# bind-address : hangi IP adreslerinden bağlantı kabul edileceği
# 0.0.0.0 -> tüm arayüzlerden (tüm IP'ler) gelen bağlantılara açık
bind-address            = 0.0.0.0
# character-set-server : sunucu varsayılan karakter seti
character-set-server    = utf8mb4
# collation-server : varsayılan karşılaştırma/karakter sıralama
collation-server        = utf8mb4_unicode_ci
